Bootstrap: docker
From: ubuntu:22.04

%files
    /home/jonah/SPARCED /SPARCED

%post
    # Set shell and environment
    export DEBIAN_FRONTEND=noninteractive
    export SHELL=/bin/bash

    # Export variables for the build process
    export BLAS_LIBS=-lopenblas
    export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH

    # Update and install basic dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
        nano \
        python3-pip \
        python3-venv \
        python3-dev \
        python3-pip \
        rsync \
        openmpi-bin \
        openmpi-common \
        libopenmpi-dev \
        libopenblas-dev \
        gcc \
        g++ \
        cmake \
        make \
        pipx \
        libgfortran5 \
        libatomic1 \
        swig \
        libhdf5-dev \
        libsbml-dev \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Change to SPARCED directory
    cd /SPARCED

    # Install the SPARCED package using pipx
    pipx ensurepath
    pipx install . --verbose --force

    # Add /usr/local/bin to runtime PATH
    echo 'export PATH=/usr/local/bin:$PATH' >> $SINGULARITY_ENVIRONMENT

    # Verify the installation
    #ls -l /root/.local/bin/sparced || { echo "SPARCED installation failed"; exit 1; }

%environment
    # Set up runtime environment variables
    export PATH=/root/.local/bin:$PATH
    export BLAS_LIBS=-lopenblas
    export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH

%runscript
    # Default command for the container
    cd /SPARCED
    exec sparced "$@"

%help
    This container enables cross-platform installation of SPARCED tools.
    Concerns and questions should be posted directly on our project
    Repository page at https://github.com/SPARCED/SPARCED/issues

